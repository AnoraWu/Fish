# setup -------------------------------------------------------------------
# Activate and restore the renv environment
if (!requireNamespace("renv", quietly = TRUE)) install.packages("renv")
if (file.exists("renv/activate.R")) {
source("renv/activate.R")
} else {
stop("renv environment not found. Please initialize renv first.")
}
#Bringing in Fishlife Package
library(utils)
library(readr)
library(devtools)
devtools::install_github("james-thorson/FishLife@2.0.1", upgrade = "never")
library(FishLife)
data(package = "FishLife")
predictions <- FishBase_and_RAM
View(predictions)
